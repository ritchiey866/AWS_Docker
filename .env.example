# PostgreSQL
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppass
POSTGRES_DB=appdb
POSTGRES_PORT=5432

# Flask
SECRET_KEY=change-me-to-a-random-secret
APP_ENV=production

# Ports
NGINX_PORT=8080
WEB_PORT=8000

# Auto-built connection string (used inside containers)
DATABASE_URL=postgresql://appuser:apppass@db:5432/appdb
